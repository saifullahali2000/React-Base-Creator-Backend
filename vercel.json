{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "node scripts/prepare-vercel.mjs && npm install",
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "memory": 2048,
      "includeFiles": "Sample_Folder/**"
    }
  }
}
